#!/usr/bin/env bash
# =============================================================================
# aurochs-recall pre-commit-secrets
#
# Scans staged file contents for secret/credential patterns. BLOCKS the commit
# on any hit. Same engine as pre-commit-pii; different rule file.
#
# Bypass (documented escape hatch): `git commit --no-verify`
# =============================================================================

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCAN="$REPO_ROOT/.githooks/_scan_engine.py"

PYTHON="${PYTHON:-python3}"
if ! command -v "$PYTHON" >/dev/null 2>&1; then
    PYTHON=python
fi

exec "$PYTHON" "$SCAN" \
    --label SECRETS \
    --rules "$REPO_ROOT/.githooks/secret-rules.txt"
